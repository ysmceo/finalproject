{
  "version": 2,
  "builds": [
    {
      "src": "backend/api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/api/index.js"
    },
    {
      "src": "/admin",
      "dest": "frontend/dist/index.html"
    },
    {
      "src": "/admin/(.*)",
      "dest": "frontend/dist/index.html"
    },
    {
      "src": "/dashboard",
      "dest": "frontend/dist/index.html"
    },
    {
      "src": "/(.*).html",
      "dest": "frontend/dist/$1.html"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/dist/index.html"
    }
  ]
}
