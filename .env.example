# Copy this file to .env and fill in values.

# Server
# Use this if port 3000 is already in use.
PORT=3000

# Payments environment
# Set to 'live' in production.
PAYMENTS_MODE=test

# Admin
ADMIN_SECRET_PASSCODE=change_this_to_strong_admin_passcode

# Paystack (required for card/debit/USSD payments)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Paystack Payment Page link (e.g. Paystack Shop / Payment Page URL)
# If provided, the website can show a “Pay with Paystack” button for manual payments.
PAYSTACK_PAYMENT_PAGE_URL=

# Stripe (optional)
# For direct Stripe payments, set STRIPE_SECRET_KEY.
# If you are using Stripe Connect, set STRIPE_CONNECTED_ACCOUNT_ID (acct_...).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECTED_ACCOUNT_ID=

# Monnify (alternative/backup for card/transfer/USSD payments)
# Set MONNIFY_ENV to 'live' or 'sandbox'. You can also explicitly set MONNIFY_BASE_URL.
MONNIFY_ENV=live
MONNIFY_BASE_URL=
MONNIFY_API_KEY=MK_PROD_xxxxxxxxxx
MONNIFY_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
MONNIFY_CONTRACT_CODE=xxxxxxxxxxxxxxxx

# Public URL where your site is reachable (required for Paystack callback)
# Local dev:
PUBLIC_BASE_URL=http://localhost:3000

# Salon bank details (used for Bank Transfer instructions)
SALON_BANK_ACCOUNT_NUMBER=0204661552
SALON_BANK_NAME=GTBank
SALON_BANK_ACCOUNT_NAME=CEO Saloon

# Email (SMTP) for admin replies
# Example for Gmail: host=smtp.gmail.com, port=465 (secure) or 587 (STARTTLS)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="CEO Unisex Salon <no-reply@ceosaloon.com>"

# Payment receipt emails
# When true, the server emails customers after successful Paystack/Stripe payment verification.
SEND_PAYMENT_EMAIL_RECEIPTS=false
# Optional BCC (e.g. your finance email)
PAYMENT_RECEIPTS_BCC=
