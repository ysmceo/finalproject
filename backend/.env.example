# Copy this file to .env and fill in values.

# Server
# Use this if port 3000 is already in use.
PORT=3000

# MongoDB (recommended for deployed environments)
MONGODB_URI=
MONGODB_DB_NAME=ceo_unisex_salon
MONGODB_STATE_COLLECTION=app_state

# Prisma database (legacy/local fallback)
DATABASE_URL="file:./dev.db"

# Runtime datastore mode
# json   -> JSON file reads/writes only
# auto   -> Mongo-primary when MONGODB_URI exists, else Prisma-primary when DATABASE_URL exists
# mongo  -> Mongo-primary reads/writes
# prisma -> Prisma-primary reads
DATA_STORE_MODE=auto

# Writable uploads directory
# Example on Render with a mounted disk: /var/data/uploads
UPLOADS_DIR=

# Payments environment
# Set to 'live' in production.
PAYMENTS_MODE=test

# Admin
ADMIN_SECRET_PASSCODE=change_this_to_strong_admin_passcode

# Paystack (required for card/debit/USSD payments)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Paystack Payment Page link (e.g. Paystack Shop / Payment Page URL)
# If provided, the website can show a “Pay with Paystack” button for manual payments.
PAYSTACK_PAYMENT_PAGE_URL=

# Stripe (optional)
# For direct Stripe payments, set STRIPE_SECRET_KEY.
# If you are using Stripe Connect, set STRIPE_CONNECTED_ACCOUNT_ID (acct_...).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECTED_ACCOUNT_ID=

# Monnify (alternative/backup for card/transfer/USSD payments)
# Set MONNIFY_ENV to 'live' or 'sandbox'. You can also explicitly set MONNIFY_BASE_URL.
MONNIFY_ENV=live
MONNIFY_BASE_URL=
MONNIFY_API_KEY=MK_PROD_xxxxxxxxxx
MONNIFY_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
MONNIFY_CONTRACT_CODE=xxxxxxxxxxxxxxxx

# Public URL where your backend is reachable (required for callbacks and generated links)
# Local dev:
PUBLIC_BASE_URL=http://localhost:3000
# Production example on Render:
# PUBLIC_BASE_URL=https://your-backend-name.onrender.com

# xAI Grok (AI chatbot)
# Add your xAI API key to enable live chatbot replies.
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-2-latest

# Salon bank details (used for Bank Transfer instructions)
SALON_BANK_ACCOUNT_NUMBER=0204661552
SALON_BANK_NAME=GTBank
SALON_BANK_ACCOUNT_NAME=CEO Saloon

# Email (SMTP) for admin replies
# Example for Gmail: host=smtp.gmail.com, port=465 (secure) or 587 (STARTTLS)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="CEO Unisex Salon <no-reply@ceosaloon.com>"

# Admin login OTP via email
# When true, one-time admin access codes are sent to the admin email instead of shown in response.
SEND_ADMIN_LOGIN_OTP_EMAILS=true

# Admin login OTP via SMS (Termii)
# When true, one-time admin access codes are also sent to the admin phone number.
SEND_ADMIN_LOGIN_OTP_SMS=true

# If OTP cannot be delivered via email/SMS, return OTP in API response as fallback.
# Useful for local development or restrictive networks.
ALLOW_ADMIN_OTP_RESPONSE_FALLBACK=true

# Payment receipt emails
# When true, the server emails customers after successful Paystack/Stripe payment verification.
SEND_PAYMENT_EMAIL_RECEIPTS=false
# Optional BCC (e.g. your finance email)
PAYMENT_RECEIPTS_BCC=

# Booking status emails (accepted/declined)
# When true, the server emails customers when admin accepts/declines a booking.
SEND_BOOKING_STATUS_EMAILS=false

# Invoice secure-link protocol (web + mobile)
# Short-lived token used for protected invoice PDF download links.
INVOICE_ACCESS_TOKEN_SECRET=change_this_to_strong_invoice_secret
INVOICE_ACCESS_TOKEN_TTL_SECONDS=900

# Admin new booking alert emails
# When true, all admin email addresses receive a notification when a new booking is created.
SEND_ADMIN_NEW_BOOKING_EMAILS=true

# Booking status SMS (accepted/declined) - Termii (Nigeria)
# When true, the server sends an SMS when admin accepts/declines a booking.
SEND_BOOKING_STATUS_SMS=false
# Termii API key
TERMII_API_KEY=
# Sender ID (must be approved in your Termii dashboard)
TERMII_SENDER_ID="CEO UNISEX"
# generic | dnd
TERMII_CHANNEL=generic
# Optional override
TERMII_BASE_URL=https://api.ng.termii.com
